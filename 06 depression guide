<script>
const phqScores = new Array(8).fill(-1);

function showTab(id, btn) {
document.querySelectorAll('.page').forEach(p=>p.classList.remove('show'));
document.getElementById(id).classList.add('show');
document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
btn.classList.add('on');
window.scrollTo(0,0);
}

function setPhq(btn, q, score) {
const item = document.querySelector(`.phq-item[data-q="${q}"]`);
item.querySelectorAll('.phq-opt').forEach(b=>b.classList.remove('on'));
btn.classList.add('on');
phqScores[q] = score;
}

function calcPhq() {
const unanswered = phqScores.filter(s=>s<0).length;
if(unanswered > 0) { alert(`กรุณาตอบให้ครบทุกข้อก่อนนะค่ะ (เหลืออีก ${unanswered} ข้อ)`); return; }

const total = phqScores.reduce((a,b)=>a+b,0);
const res = document.getElementById('phqResult');
res.style.display='block';

const fillPct = Math.round((total/24)*100);
document.getElementById('phqFill').style.width = fillPct+'%';
document.getElementById('phqScoreLabel').textContent = `คะแนน ${total} / 24`;

let cls, title, body, fillColor;
if(phqScores[7] >= 2) {
cls='severe'; title='⚠️ ต้องพบแพทย์ทันที';
body='คุณตอบว่ามีความคิดอยากทำร้ายตัวเอง กรุณาบอกคนในบ้านและไปพบแพทย์ทันทีนะค่ะ ไม่ต้องอาย ไม่ต้องรอนัด';
fillColor='#D63031';
} else if(total <= 4) {
cls='none'; title='✅ อยู่ในเกณฑ์ปกติ';
body='คะแนนของคุณอยู่ในระดับปกติค่ะ แต่ถ้ารู้สึกเปลี่ยนแปลงในอนาคต ประเมินซ้ำได้เลยนะค่ะ';
fillColor='#27AE60';
} else if(total <= 9) {
cls='mild'; title='💛 ซึมเศร้าระดับเล็กน้อย';
body='คะแนนบ่งชี้ว่ามีอาการซึมเศร้าเล็กน้อยค่ะ แจ้งแพทย์ในวันนัดถัดไปเพื่อประเมินเพิ่มเติม และลองทำกิจกรรมที่ช่วยได้ในแท็บ "ผู้ป่วย" ค่ะ';
fillColor='#F59E0B';
} else if(total <= 19) {
cls='mod'; title='🟠 ซึมเศร้าระดับปานกลาง';
body='คะแนนบ่งชี้ว่ามีอาการซึมเศร้าระดับปานกลางค่ะ ควรพบแพทย์ก่อนนัดถัดไปได้เลย มาได้ก่อนนัดค่ะ ไม่ต้องรอ แพทย์สามารถช่วยได้มากค่ะ';
fillColor='#EA580C';
} else {
cls='mod'; title='🔴 ซึมเศร้าระดับรุนแรง';
body='คะแนนสูงมากค่ะ กรุณาพบแพทย์โดยเร็วที่สุด มาได้เลยไม่ต้องรอนัด แพทย์มีวิธีช่วยเหลือที่ได้ผลดีค่ะ';
fillColor='#D63031';
}

res.className='phq-result '+cls;
document.getElementById('phqFill').style.background = fillColor;
document.getElementById('phqResTitle').textContent = title;
document.getElementById('phqResBody').textContent = body;
res.scrollIntoView({behavior:'smooth'});
}
</script>
